{
	"name": "@cap/mobile",
	"version": "1.0.0",
	"private": true,
	"main": "expo-router/entry",
	"scripts": {
		"build:development": "pnpm dlx eas-cli@21.0.2 build --platform ios --profile development",
		"build:preview": "pnpm dlx eas-cli@21.0.2 build --platform ios --profile preview",
		"build:production": "pnpm dlx eas-cli@21.0.2 build --platform ios --profile production",
		"dev": "CAP_MOBILE_DISABLE_ASSOCIATED_DOMAINS=1 CAP_MOBILE_BUILD_REACT_NATIVE_FROM_SOURCE=1 sh -c 'node scripts/prepare-ios-development.mjs && if [ \"${CAP_MOBILE_DEVICE:-simulator}\" = \"physical\" ]; then node scripts/run-ios-device.mjs; else node scripts/run-ios-simulator.mjs; fi'",
		"dev:device": "pnpm run dev:physical",
		"dev:physical": "CAP_MOBILE_DEVICE=physical pnpm run dev",
		"eas:config": "pnpm dlx eas-cli@21.0.2 config --platform ios",
		"start": "expo start --dev-client",
		"submit:production": "pnpm dlx eas-cli@21.0.2 submit --platform ios --profile production --latest",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prebuild:ios": "expo prebuild --platform ios --no-install",
		"ios": "CAP_MOBILE_DISABLE_ASSOCIATED_DOMAINS=1 CAP_MOBILE_BUILD_REACT_NATIVE_FROM_SOURCE=1 sh -c 'node scripts/prepare-ios-development.mjs && expo run:ios'",
		"update:preview": "pnpm dlx eas-cli@21.0.2 update --channel preview --environment preview",
		"update:production": "pnpm dlx eas-cli@21.0.2 update --channel production --environment production"
	},
	"dependencies": {
		"@cap/web-domain": "workspace:*",
		"@expo/metro-runtime": "~55.0.12",
		"@shopify/flash-list": "2.0.2",
		"effect": "^3.18.4",
		"expo": "~55.0.28",
		"expo-apple-authentication": "~55.0.15",
		"expo-build-properties": "~55.0.15",
		"expo-camera": "~55.0.21",
		"expo-clipboard": "~55.0.15",
		"expo-constants": "~55.0.17",
		"expo-dev-client": "~55.0.37",
		"expo-device": "~55.0.19",
		"expo-document-picker": "~55.0.15",
		"expo-file-system": "~55.0.24",
		"expo-font": "~55.0.7",
		"expo-glass-effect": "~55.0.11",
		"expo-haptics": "~55.0.16",
		"expo-image": "~55.0.10",
		"expo-image-picker": "~55.0.22",
		"expo-linking": "~55.0.15",
		"expo-media-library": "~55.0.19",
		"expo-router": "~55.0.17",
		"expo-secure-store": "~55.0.16",
		"expo-sharing": "~55.0.22",
		"expo-splash-screen": "~55.0.23",
		"expo-symbols": "~55.0.8",
		"expo-updates": "~55.0.26",
		"expo-video": "~55.0.19",
		"expo-web-browser": "~55.0.18",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-native": "0.83.6",
		"react-native-gesture-handler": "~2.30.0",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-svg": "15.15.3",
		"react-native-web": "~0.21.0",
		"react-native-worklets": "0.7.4"
	},
	"devDependencies": {
		"@testing-library/react-native": "^13.3.3",
		"@types/react": "19.2.14",
		"@types/react-test-renderer": "^19.1.0",
		"babel-preset-expo": "~55.0.21",
		"react-test-renderer": "19.2.0",
		"typescript": "~5.9.2",
		"vitest": "^3.2.0"
	}
}
