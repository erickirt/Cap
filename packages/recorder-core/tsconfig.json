{
	"extends": "../config/base.tsconfig.json",
	"include": ["src", "__tests__"],
	"exclude": ["dist", "node_modules"],
	"compilerOptions": {
		"moduleResolution": "bundler",
		"composite": true,
		"outDir": "dist",
		"noEmit": false,
		"emitDeclarationOnly": true,
		"lib": ["DOM", "DOM.Iterable", "ES2022"]
	}
}
